# Server
NODE_ENV=production
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=augustus
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_POOL_MAX=20

# Redis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# S3-compatible Object Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=augustus

# Anthropic Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Meta Cloud API (WhatsApp)
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v19.0
META_EMBEDDED_SIGNUP_CONFIG_ID=

# Paynow
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RETURN_URL=https://yourdomain.com/payment/return
PAYNOW_RESULT_URL=https://yourdomain.com/api/payments/paynow/webhook

# Email (SendGrid or AWS SES)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Augustus

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Withdrawals
WITHDRAWAL_AUTO_PROCESS_THRESHOLD=50

# Encryption (AES-256-GCM) — must be a 64-character hex string (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# Base URL for this API server (used to construct webhook callback URLs)
BASE_URL=https://api.yourdomain.com

# Frontend URL (for email redirect links)
FRONTEND_URL=https://yourdomain.com
